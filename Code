#define BLYNK_TEMPLATE_ID "TMPLxxxxxxx"
#define BLYNK_TEMPLATE_NAME "ESP32 Home Automation"
#define BLYNK_AUTH_TOKEN "YourAuthToken"

#include <WiFi.h>
#include <BlynkSimpleEsp32.h>

char ssid[] = "Your_WiFi_Name";
char pass[] = "Your_WiFi_Password";

// Relay Pins
#define RELAY1 23
#define RELAY2 22
#define RELAY3 21
#define RELAY4 19

// Push Buttons
#define SW1 13
#define SW2 12
#define SW3 14
#define SW4 27

BlynkTimer timer;

// ---------------- BLYNK ----------------

BLYNK_WRITE(V0)
{
  digitalWrite(RELAY1, !param.asInt());
}

BLYNK_WRITE(V1)
{
  digitalWrite(RELAY2, !param.asInt());
}

BLYNK_WRITE(V2)
{
  digitalWrite(RELAY3, !param.asInt());
}

BLYNK_WRITE(V3)
{
  digitalWrite(RELAY4, !param.asInt());
}

// ---------------- MANUAL SWITCH ----------------

void checkSwitches()
{
  static int last1=1,last2=1,last3=1,last4=1;

  int s1=digitalRead(SW1);
  int s2=digitalRead(SW2);
  int s3=digitalRead(SW3);
  int s4=digitalRead(SW4);

  if(s1==0 && last1==1)
  {
    digitalWrite(RELAY1,!digitalRead(RELAY1));
    Blynk.virtualWrite(V0,!digitalRead(RELAY1));
  }

  if(s2==0 && last2==1)
  {
    digitalWrite(RELAY2,!digitalRead(RELAY2));
    Blynk.virtualWrite(V1,!digitalRead(RELAY2));
  }

  if(s3==0 && last3==1)
  {
    digitalWrite(RELAY3,!digitalRead(RELAY3));
    Blynk.virtualWrite(V2,!digitalRead(RELAY3));
  }

  if(s4==0 && last4==1)
  {
    digitalWrite(RELAY4,!digitalRead(RELAY4));
    Blynk.virtualWrite(V3,!digitalRead(RELAY4));
  }

  last1=s1;
  last2=s2;
  last3=s3;
  last4=s4;
}

// ---------------- SETUP ----------------

void setup()
{
  Serial.begin(115200);

  pinMode(RELAY1,OUTPUT);
  pinMode(RELAY2,OUTPUT);
  pinMode(RELAY3,OUTPUT);
  pinMode(RELAY4,OUTPUT);

  pinMode(SW1,INPUT_PULLUP);
  pinMode(SW2,INPUT_PULLUP);
  pinMode(SW3,INPUT_PULLUP);
  pinMode(SW4,INPUT_PULLUP);

  digitalWrite(RELAY1,HIGH);
  digitalWrite(RELAY2,HIGH);
  digitalWrite(RELAY3,HIGH);
  digitalWrite(RELAY4,HIGH);

  Blynk.begin(BLYNK_AUTH_TOKEN, ssid, pass);

  timer.setInterval(100L, checkSwitches);
}

// ---------------- LOOP ----------------

void loop()
{
  Blynk.run();
  timer.run();
}
